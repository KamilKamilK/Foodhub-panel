<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:gedmo="http://gediminasm.org/schemas/orm/doctrine-extensions-mapping">
  <entity xmlns:gedmo="http://gediminasm.org/schemas/orm/doctrine-extensions-mapping" name="App\ClientContext\Domain\Entity\ClientAdditionalDevice" table="lsi_client_additional_device">
    <id name="id" type="integer">
      <generator strategy="IDENTITY"/>
    </id>
    <field xmlns:gedmo="http://gediminasm.org/schemas/orm/doctrine-extensions-mapping" name="createdAt" type="datetime">
      <gedmo:timestampable xmlns:gedmo="http://gediminasm.org/schemas/orm/doctrine-extensions-mapping" on="create"/>
    </field>
    <field xmlns:gedmo="http://gediminasm.org/schemas/orm/doctrine-extensions-mapping" name="updatedAt" type="datetime">
      <gedmo:timestampable xmlns:gedmo="http://gediminasm.org/schemas/orm/doctrine-extensions-mapping" on="update"/>
    </field>
    <field name="isActive" type="boolean"/>
    <field name="validFrom" type="date"/>
    <field name="expiredAt" type="date"/>
    <many-to-one field="clientLicense" target-entity="App\ClientContext\Domain\Entity\ClientLicense" inversed-by="additionalDevices">
      <join-column name="client_license_id" referenced-column-name="id"/>
    </many-to-one>
    <many-to-one field="licenseAdditionalDevice" target-entity="App\LicenseContext\Domain\Entity\LicenseAdditionalDevice" inversed-by="clientAdditionalDevices">
      <join-column name="license_additional_device_id" referenced-column-name="id"/>
    </many-to-one>
  </entity>
</doctrine-mapping>
