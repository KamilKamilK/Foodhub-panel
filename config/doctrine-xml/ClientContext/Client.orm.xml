<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:gedmo="http://gediminasm.org/schemas/orm/doctrine-extensions-mapping">
  <entity name="App\ClientContext\Domain\Entity\Client" repository-class="App\ClientContext\Infrastructure\Persistence\Repository\ClientRepository" table="lsi_client">
    <id name="id" type="integer">
      <generator strategy="IDENTITY"/>
    </id>
    <field name="firstname" type="string" length="255" nullable="true"/>
    <field name="lastname" type="string" length="255" nullable="true"/>
    <field name="phone" type="string" length="255" nullable="true"/>
    <field name="email" type="string" length="255" nullable="true"/>
    <field name="regSpecialCode" type="string" length="255" nullable="true"/>
    <field name="subdomain" type="string" length="255" nullable="false"/>
    <field name="dbName" type="string" length="255" nullable="false"/>
    <field name="dbPassword" type="string" length="255" nullable="false"/>
    <field name="dbUser" type="string" length="255" nullable="false"/>
    <field name="createdAt" type="date" nullable="true"/>
    <embedded name="company" class="App\ClientContext\Domain\Entity\Company"/>
    <embedded name="address" class="App\ClientContext\Domain\Entity\Address"/>
    <one-to-many field="users" target-entity="App\ClientContext\Domain\Entity\ClientUser" mapped-by="client"/>
    <one-to-many field="clientLicenses" target-entity="App\ClientContext\Domain\Entity\ClientLicense" mapped-by="client">
      <cascade>
        <cascade-persist/>
      </cascade>
      <order-by>
        <order-by-field name="validFrom" direction="ASC"/>
      </order-by>
    </one-to-many>
    <many-to-many field="agreements" target-entity="App\ClientContext\Domain\Entity\Agreement" mapped-by="clients">
      <cascade>
        <cascade-persist/>
      </cascade>
    </many-to-many>
  </entity>
</doctrine-mapping>
