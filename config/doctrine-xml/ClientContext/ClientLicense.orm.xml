<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:gedmo="http://gediminasm.org/schemas/orm/doctrine-extensions-mapping">
  <entity xmlns:gedmo="http://gediminasm.org/schemas/orm/doctrine-extensions-mapping" name="App\ClientContext\Domain\Entity\ClientLicense" repository-class="App\ClientContext\Infrastructure\Persistence\Repository\ClientLicenseRepository" table="lsi_client_license">
    <id name="id" type="integer">
      <generator strategy="IDENTITY"/>
    </id>
    <field xmlns:gedmo="http://gediminasm.org/schemas/orm/doctrine-extensions-mapping" name="createdAt" type="datetime">
      <gedmo:timestampable xmlns:gedmo="http://gediminasm.org/schemas/orm/doctrine-extensions-mapping" on="create"/>
    </field>
    <field xmlns:gedmo="http://gediminasm.org/schemas/orm/doctrine-extensions-mapping" name="updatedAt" type="datetime">
      <gedmo:timestampable xmlns:gedmo="http://gediminasm.org/schemas/orm/doctrine-extensions-mapping" on="update"/>
    </field>
    <field name="specialCode" type="string" length="6" nullable="true"/>
    <field name="period" type="string" nullable="false">
      <options>
        <option name="default">MONTH</option>
      </options>
    </field>
    <field name="validFrom" type="date"/>
    <field name="expiredAt" type="date"/>
    <many-to-one field="license" target-entity="App\LicenseContext\Domain\Entity\License" inversed-by="clientLicenses">
      <join-column name="license_id" referenced-column-name="id"/>
    </many-to-one>
    <many-to-one field="client" target-entity="App\ClientContext\Domain\Entity\Client" inversed-by="clientLicenses">
      <join-column name="client_id" referenced-column-name="id"/>
    </many-to-one>
    <one-to-many field="addons" target-entity="App\ClientContext\Domain\Entity\ClientAddon" mapped-by="clientLicense">
      <cascade>
        <cascade-persist/>
      </cascade>
      <order-by>
        <order-by-field name="id" direction="ASC"/>
      </order-by>
    </one-to-many>
    <one-to-many field="additionalDevices" target-entity="App\ClientContext\Domain\Entity\ClientAdditionalDevice" mapped-by="clientLicense">
      <cascade>
        <cascade-persist/>
      </cascade>
      <order-by>
        <order-by-field name="id" direction="ASC"/>
      </order-by>
    </one-to-many>
  </entity>
</doctrine-mapping>
