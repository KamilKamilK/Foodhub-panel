<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:gedmo="http://gediminasm.org/schemas/orm/doctrine-extensions-mapping">
  <entity name="App\ClientContext\Domain\Entity\Agreement" repository-class="App\ClientContext\Infrastructure\Persistence\Repository\AgreementRepository" table="lsi_agreement">
    <id name="id" type="integer">
      <generator strategy="IDENTITY"/>
    </id>
    <field name="title" type="text" nullable="true"/>
    <field name="description" type="text" nullable="true"/>
    <field name="required" type="boolean" nullable="true"/>
    <field name="locale" type="string" nullable="true"/>
    <many-to-many field="clients" target-entity="App\ClientContext\Domain\Entity\Client" inversed-by="agreements">
      <join-table name="lsi_client_agreement">
        <join-columns>
          <join-column name="agreement_id" referenced-column-name="id"/>
        </join-columns>
        <inverse-join-columns>
          <join-column name="client_id" referenced-column-name="id"/>
        </inverse-join-columns>
      </join-table>
    </many-to-many>
  </entity>
</doctrine-mapping>
