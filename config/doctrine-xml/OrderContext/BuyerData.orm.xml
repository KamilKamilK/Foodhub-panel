<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping">
  <embeddable name="App\OrderContext\Domain\ValueObject\BuyerData">
    <field name="name"       type="string" length="255" nullable="false"/>
    <field name="vatNumber"  type="string" length="255" nullable="false"/>
    <field name="street"     type="string" length="255" nullable="false"/>
    <field name="house"      type="string" length="255" nullable="false"/>
    <field name="flat"       type="string" length="255" nullable="true"/>
    <field name="city"       type="string" length="255" nullable="false"/>
    <field name="zip"        type="string" length="255" nullable="false"/>
  </embeddable>
</doctrine-mapping>
