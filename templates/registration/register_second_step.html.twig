{% form_theme form 'form_div_layout.html.twig' %}
<div class="row min-height">
    <div class="col-12 col-lg-6">
        <section id="signup" class="signup-section">
            <div class="mx-auto text-center form-container">
                {% if success is defined and success is same as(true) %}
                    <p class="title-main text-center justify-content-center">
                        {{ 'registration.process.success-title' | trans }}
                    </p>
                    <p class="title-description text-center">
                        {{ 'registration.process.success-description' | trans }}
                    </p>

                    <div class="mt-3 signinBtn">
                        <a href="{{ installationResult }}" class="btn signinBtn"
                           type="button">{{ 'action.signin' | trans }}</a>
                    </div>

                    <div class="mt-5">
                        <p style="color: #979797">{{ 'registration.desc.resend' | trans }}</p>
                        <a href="{{ path('lsi_resend_mail', {'email': form.user.email.vars.value, 'installationResult': installationResult }) }}" class="btn btn-light resendBtn"
                           type="button">{{ 'action.resend' | trans }}</a>
                    </div>
                {% endif %}
                {% if success is defined and success is same as(false) %}
                    {{ form_start(form, {'attr': {'class': 'form'}}) }}
                        {% include 'util/flash.html.twig' %}
                        <div class="user-agreements {% if form.agreementIds.vars.valid and form.agreementIds.vars.data|length > 0 %}d-none{% endif %}">
                            <p class="title-main text-left">
                                {{ 'registration.title' | trans }}
                            </p>
                            <p class="title-description text-left">
                                {{ 'registration.desc.second' | trans }}
                            </p>

                            <div class="my-5">
                            {% for key, agreement in form.agreementIds %}
                                <div class="form-group checkbox-group">
                                    <div class="custom-control custom-checkbox text-left">
                                        {% set agreementFeatures = agreements[key] %}
                                        {% if agreementFeatures.required %}
                                            {{ form_widget(agreement, { 'attr': {'class': 'custom-control-input', 'required': true }}) }}
                                        {% else %}
                                            {{ form_widget(agreement, { 'attr': {'class': 'custom-control-input' }}) }}
                                        {% endif %}
                                        <label class="custom-control-label" for="{{ agreement.vars.id }}">
                                            {{ agreements[key].title|raw }}
                                            {% if agreementFeatures.required %}
                                                <span class="text-danger">*</span>
                                            {% endif %}
                                        </label>
                                    </div>
                                    <div class="error text-left invalid-feedback h-auto {% if not agreement.vars.valid %}d-block{% else %}d-none{% endif %}">
                                        {{ 'exception.constraint.not_blank' | trans({}, 'exception') }}
                                    </div>
                                </div>
                            {% endfor %}
                            </div>

                            <div class="form-group d-flex justify-content-center">
                                <div id="submit-agreements" class="button-register">{{ 'action.save' | trans }}</div>
                            </div>
                        </div>
                        <div class="user-data {% if not form.agreementIds.vars.valid or form.agreementIds.vars.data|length == 0 %}d-none{% endif %}">
                            <p class="title-main">
                                {{ 'registration.title' | trans }}
                            </p>
                            <p class="title-description">
                                {{ 'registration.desc.third' | trans | nl2br }}
                            </p>
                            <div class="mt-5">
                                <div class="form-group inner-addon right-addon">
                                    <div>
                                        <i class="flaticon flaticon-user"></i>
                                        {{ form_widget(form.user.name, {'attr': {'class': 'form-control flex-fill'}}) }}
                                        {{ form_label(form.user.name) }}
                                    </div>
                                    {{ form_errors(form.user.name) }}
                                </div>
                                <div class="form-group inner-addon right-addon">
                                    <div>
                                        <i class="flaticon flaticon-user"></i>
                                        {{ form_widget(form.user.surname, {'attr': {'class': 'form-control flex-fill'}}) }}
                                        {{ form_label(form.user.surname) }}
                                    </div>
                                    {{ form_errors(form.user.surname) }}
                                </div>
                                <div class="form-group inner-addon right-addon">
                                    <div>
                                        <i class="flaticon flaticon-phone"></i>
                                        {{ form_widget(form.user.phone, {'attr': {'class': 'form-control flex-fill'}}) }}
                                        {{ form_label(form.user.phone) }}
                                    </div>
                                    {{ form_errors(form.user.phone) }}
                                </div>
                                <div class="form-group inner-addon right-addon">
                                    <div>
                                        <i class="flaticon flaticon-note"></i>
                                        {{ form_widget(form.user.email, {'attr': {'class': 'form-control flex-fill', 'autocomplete': 'username'}}) }}
                                        {{ form_label(form.user.email) }}
                                    </div>
                                    {{ form_errors(form.user.email) }}
                                </div>
                                <div class="form-group inner-addon right-addon">
                                    <div>
                                        <i id="passwordWatch" class="flaticon flaticon-eye-2"></i>
                                        {{ form_widget(form.user.password.first, {'attr': {'class': 'form-control flex-fill','autocomplete': 'password'}}) }}
                                        {{ form_label(form.user.password.first) }}
                                    </div>
                                    {{ form_errors(form.user.password.first) }}
                                </div>
                                <div class="form-group inner-addon right-addon">
                                    <div>
                                        <i id="passwordWatch2" class="flaticon flaticon-eye-2"></i>
                                        {{ form_widget(form.user.password.second, {'attr': {'class': 'form-control flex-fill','autocomplete': 'password'}}) }}
                                        {{ form_label(form.user.password.second) }}
                                    </div>
                                    {{ form_errors(form.user.password.second) }}
                                </div>
                                <div class="form-group inner-addon right-addon row special-code">
                                    <div class="col-8 text-left">
                                        <span>Kod specjalny</span>
                                    </div>
                                    <div class="col-4">
                                        <div>
                                            <i class="flaticon flaticon-special-code"></i>
                                            {{ form_widget(form.user.specialCode, {'attr': {'class': 'form-control flex-fill'}}) }}
                                            {{ form_label(form.user.specialCode) }}
                                        </div>
                                    </div>
                                    <span class="col-12">
                                        {{ form_errors(form.user.specialCode) }}
                                    </span>
                                </div>
                            </div>
                            <div class="form-group bottom-height">
                                <button id="registration-submit" type="submit">{{ 'action.register' | trans }}</button>
                            </div>
                            {{ form_widget(form.type, {'attr': {'class': 'form-control flex-fill mr-0 mr-sm-2 mb-5 mb-sm-3'}}) }}
                            {{ form_errors(form.type) }}
                            {{ form_widget(form.withProducts) }}
                            {{ form_widget(form._token) }}
                        </div>
                    {{ form_end(form, {'render_rest': false}) }}
                {% endif %}
            </div>
        </section>
        {% if success is defined and success is same as(false) %}
            <section id="bottom" class="bottom-section">
                <div class="login">
                    {{ 'registration.bottom.have_account' | trans }}
                    <a href="{{ appUrl ~ '/#/auth/login' }}">{{ 'registration.bottom.sign_in' | trans }}</a>
                </div>
                <div class="copyrights">
                    {{ 'registration.bottom.copyright' | trans({'%year%': date('now')|date('Y')}) }}
                </div>
            </section>
        {% endif %}
        {% if success is defined and success is same as(true) %}
            <section id="bottom" class="bottom-section bg-transparent">
                <div class="copyrights pt-2">
                    {{ 'registration.bottom.copyright' | trans({'%year%': date('now')|date('Y')}) }}
                </div>
            </section>
        {% endif %}
    </div>
    <div class="d-none d-lg-block col-lg-6 image-background-container min-height"></div>
</div>
<script route="{{ path('lsi_register_second', {'type': type}) }}"></script>
{{ encore_entry_script_tags('js/lp/events') }}
