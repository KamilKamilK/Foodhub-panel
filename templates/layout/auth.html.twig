{% import 'macros.html.twig' as macros %}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title></title>
    {% block stylesheets %}
        {{ encore_entry_link_tags('css/fhp/app') }}
    {% endblock %}
</head>
<body class="auth-layout">
<main>
    <div class="card bg-white col-md-4 col-lg-3">
        <div class="card-body">
            <section class="brand">
                <img alt="LSI Software" src="{{ asset('/images/logo.png') }}" />
            </section>
            {{ macros.messages()}}
            {% block body %}{% endblock %}
        </div>
    </div>
</main>
{% block javascripts %}
    {{ encore_entry_script_tags('js/fhp/app') }}
{% endblock %}
</body>
</html>
